# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-change-in-production

# 数据库
DATABASE_URL=postgresql+asyncpg://stockview:stockview123@postgres:5432/stockview

# Redis
REDIS_URL=redis://redis:6379/0

# 数据源配置
PRIMARY_DATA_SOURCE=eastmoney
FALLBACK_DATA_SOURCE=sina

# AI 模块配置
AI_ADAPTER=mock
AI_SERVICE_URL=http://localhost:8001
AI_REQUEST_TIMEOUT=30

# Celery 配置
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 行情采集配置
QUOTE_COLLECT_INTERVAL=3
QUOTE_CACHE_TTL=5

# JWT 配置
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
